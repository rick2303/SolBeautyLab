# Copia este archivo a .env.local (local) o configúralo en Vercel (producción).
# NUNCA subas .env.local con valores reales — ya está en .gitignore.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron (protege /api/cron/*). Un string largo aleatorio. ---
CRON_SECRET=

# --- Web Push (generar con: npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@solbeautylab.cc
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Twilio (SMS). Dejar en blanco = SMS apagado, no rompe nada. ---
TWILIO_ACCOUNT_SID=
# Autenticación por API Key (recomendado) …
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# … o clásica (Account SID + Auth Token). Usa una u otra.
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- URL pública del sitio (para los links de confirmación por SMS) ---
NEXT_PUBLIC_APP_URL=https://solbeautylab.cc
